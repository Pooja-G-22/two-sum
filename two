#include <stdio.h>

void twoSum(int nums[], int size, int target) {
    int i, j;

    for(i = 0; i < size; i++) {
        for(j = i + 1; j < size; j++) {
            if(nums[i] + nums[j] == target) {
                printf("[%d, %d]\n", i, j);
                return;
            }
        }
    }
}

int main() {
    int nums[] = {2, 7, 11, 15};
    int target = 9;
    int size = sizeof(nums) / sizeof(nums[0]);

    twoSum(nums, size, target);

    return 0;
}two
